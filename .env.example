SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_CHANNEL_ID=C0XXXXXXXXX
GOOGLE_SHEET_ID=your-spreadsheet-id-here
PORT=8001

# For EC2/local: path to the service account JSON file
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# For Vercel: paste the entire JSON content as a single-line string
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...","token_uri":"..."}

# Groq Cloud LLM (optional — falls back to regex parser if not set)
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
